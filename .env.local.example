# Frontend-only Vite environment variables.
# Copy this file to .env.local and fill in your own Supabase project values.
#
# Never put service role keys, database passwords, OpenAI keys, SMTP secrets,
# or Google client secrets in frontend env files.

VITE_SUPABASE_URL= ""
VITE_SUPABASE_PUBLISHABLE_KEY=""

SUPABASE_ACCESS_TOKEN=""
SUPABASE_DB_URL=""
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
OPENAI_API_KEY=""
OPENAI_REALTIME_MODEL="gpt-realtime-2"
OPENAI_REALTIME_VOICE="marin"